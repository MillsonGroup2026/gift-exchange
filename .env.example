# ---------------------------------------------------------------------------
# Supabase (Project Settings -> API)
# ---------------------------------------------------------------------------
# Public — safe to expose to the browser. RLS enforces all access control.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRET — server only. Bypasses RLS. Used for seeding/admin tasks only.
# Never import this into a Client Component or expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Used for magic-link redirect URLs. Local dev: http://localhost:3000
# On Render: set to the live service URL (https://gift-exchange-xxxx.onrender.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Anthropic (Phase 6 — server only, never shipped to the client)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
